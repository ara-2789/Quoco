# .env.test — TEST-DB BRANCH ONLY. Copy to .env.test and fill in.
# .env.test is gitignored (.gitignore: `.env*`) — NEVER commit real secrets.
#
# These vars are read ONLY by vitest.config.ts (test mode). They are kept
# physically separate from .env.local so the PRODUCTION service key is never
# loaded into scope during a test run.
#
# The allowlist guard (test/setup/guard.ts) ABORTS the entire suite unless the
# resolved project ref equals the test-db branch ref exfccwlrhoutkgrlikod.
# Pointing these at any other database (prod, staging, a typo) is a hard fail.

# Test-db branch URL — https://exfccwlrhoutkgrlikod.supabase.co
SUPABASE_TEST_URL=https://exfccwlrhoutkgrlikod.supabase.co

# Service-role key for the TEST-DB BRANCH ONLY (never the prod key).
SUPABASE_TEST_SERVICE_ROLE_KEY=your-test-branch-service-role-key

# Anon (publishable) key for the TEST-DB BRANCH. Needed by the migration-007
# suite to mint real user-JWT clients (signInWithPassword) so RLS isolation is
# actually exercised — the service-role client bypasses RLS and proves nothing.
SUPABASE_TEST_ANON_KEY=your-test-branch-anon-key

# Must equal the allowed test-db ref. Asserted against the URL-derived ref.
SUPABASE_TEST_PROJECT_REF=exfccwlrhoutkgrlikod
